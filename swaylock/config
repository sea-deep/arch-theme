# Verification Colors
ring-ver-color=7aa2f7
inside-ver-color=1a1b26
line-ver-color=1a1b2600

# Wrong Colors
ring-wrong-color=f7768e
inside-wrong-color=1a1b26
line-wrong-color=1a1b2600

# Keypress Colors
key-hl-color=7dcfff
bs-hl-color=f7768e

# Font
font=JetBrainsMono Nerd Font
text-color=c0caf5

# TokyoNight swaylock-effects config
ignore-empty-password
show-failed-attempts

# Blur the current screen (requires swaylock-effects)
screenshots
clock
effect-blur=7x5
effect-vignette=0.5:0.5

# Tokyo Night Background Overlay
color=1a1b2680

# Ring Colors
ring-color=bb9af7
inside-color=1a1b26

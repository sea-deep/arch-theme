{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 3,
    "margin-left": 3,
    "margin-right": 3,
    "margin-bottom": 0,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/swaync", "group/hardware", "custom/power"],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "backlight", "custom/battery"]
    },

    "tray": {
        "spacing": 10
    },

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/window": {
        "max-length": 50
    },
    "clock": {
        "format": "<span color='#bb9af7'>َ°¥”</span>  {:%I:%M %p   <span color='#7aa2f7'>َ°ƒ­</span>  %b %e}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/battery": {
        "exec": "~/.config/waybar/battery.sh",
        "on-click": "~/.config/waybar/tlp_menu.sh",
        "return-type": "json",
        "interval": 10,
        "format": "{}"
    },
    "network": {
        "format-wifi": "<span color='#7dcfff'>َ°¤¨</span>   {essid}",
        "format-ethernet": "<span color='#7dcfff'>َ°ˆ€</span>   {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr} َ°ٹ—",
        "format-linked": "{ifname} (No IP) َ°ˆ€",
        "format-disconnected": "<span color='#F7768E'>َ°¤­</span>   Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "tooltip": false,
        "format": "<span color='#7aa2f7'>{icon}</span>  {volume}%",
        "format-bluetooth": "<span color='#7aa2f7'>{icon}َ°‚°</span>  {volume}%",
        "format-bluetooth-muted": "<span color='#F7768E'>َ°–پَ°‚°</span>",
        "format-muted": "<span color='#F7768E'>َ°–پ</span>  Muted",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹‹",
            "headset": "َ°‹‹",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "~/.config/waybar/pavu_toggle.sh",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "backlight": {
        "tooltip": false,
        "format": "<span color='#e0af68'>{icon}</span>  {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-click-middle": "~/.config/waybar/toggle_idle.sh",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },
    "bluetooth": {
        "format": "<span color='#bb9af7'>َ°‚¯</span>  {status}",
        "format-disabled": "<span color='#F7768E'>َ°‚²</span>  Disabled",
        "format-connected": "<span color='#bb9af7'>َ°‚±</span>  {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "pkill blueman-manager || blueman-manager"
    },
    "custom/swaync": {
        "tooltip": false,
        "format": "<span color='#bb9af7'> {icon} </span>",
        "format-icons": {
            "notification": "َ±…«",
            "none": "َ°‚ڑ",
            "dnd-notification": "َ±ڈ§",
            "dnd-none": "َ±ڈ§",
            "inhibited-notification": "َ±…«",
            "inhibited-none": "َ°‚ڑ",
            "dnd-inhibited-notification": "َ±ڈ§",
            "dnd-inhibited-none": "َ±ڈ§"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/power": {
        "format": " ï€‘ ",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu.sh",
        "exec": "echo 'ï€‘'",
        "interval": "once"
    }
}

{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 3,
    "margin-left": 3,
    "margin-right": 3,
    "margin-bottom": 0,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/recorder", "custom/clipse", "custom/capslock", "custom/autosleep", "tray", "custom/swaync", "group/hardware", "custom/power"],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "backlight", "custom/battery"]
    },

    "tray": {
        "spacing": 10
    },

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/window": {
        "max-length": 40
    },
    "clock": {
        "format": "<span color='#bb9af7'>َ°¥”</span>  {:%I:%M %p   <span color='#7aa2f7'>َ°ƒ­</span>  %b %e}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/battery": {
        "exec": "~/.config/waybar/battery.sh",
        "on-click": "~/.config/waybar/tlp_menu.sh",
        "return-type": "json",
        "interval": 10,
        "format": "<span color='#39c5bb'>{alt}</span> {text}"
    },
    "network": {
        "format-wifi": "<span color='#7dcfff'>َ°¤¨</span>   {essid}",
        "format-ethernet": "<span color='#7dcfff'>َ°ˆ€</span>   {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr} َ°ٹ—",
        "format-linked": "{ifname} (No IP) َ°ˆ€",
        "format-disconnected": "<span color='#F7768E'>َ°¤­</span>   Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "tooltip": true,
        "tooltip-format": "Scroll: Adjust Volume\nLeft Click: Pavucontrol\nMiddle Click: Mute/Unmute",
        "format": "<span color='#7aa2f7'>{icon}</span> â€‰â€ٹ{volume}%",
        "format-bluetooth": "<span color='#7aa2f7'>{icon}َ°‚°</span> â€‰â€ٹ{volume}%",
        "format-bluetooth-muted": "<span color='#F7768E'>َ°–پَ°‚°</span>",
        "format-muted": "<span color='#F7768E'>َ°–پ</span> â€‰â€ٹMuted",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹‹",
            "headset": "َ°‹‹",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "~/.config/waybar/pavu_toggle.sh",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "backlight": {
        "tooltip": true,
        "tooltip-format": "Scroll: Adjust Brightness\nMiddle Click: Toggle Caffeine Mode",
        "format": "<span color='#e0af68'>{icon}</span> â€‰â€ٹ{percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-click-middle": "~/.config/waybar/toggle_idle.sh",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },
    "bluetooth": {
        "format": "<span color='#bb9af7'>َ°‚¯</span>  {status}",
        "format-disabled": "<span color='#F7768E'>َ°‚²</span>  Disabled",
        "format-connected": "<span color='#bb9af7'>َ°‚±</span>  {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "pkill blueman-manager || blueman-manager"
    },
    "custom/swaync": {
        "tooltip": true,
        "format": "<span color='#bb9af7'> {icon} </span>",
        "format-icons": {
            "notification": "َ±…«",
            "none": "َ°‚ڑ",
            "dnd-notification": "َ±ڈ§",
            "dnd-none": "َ±ڈ§",
            "inhibited-notification": "َ±…«",
            "inhibited-none": "َ°‚ڑ",
            "dnd-inhibited-notification": "َ±ڈ§",
            "dnd-inhibited-none": "َ±ڈ§"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "on-click-middle": "swaync-client -d -sw",
        "escape": true
    },
    "custom/power": {
        "format": " ï€‘ ",
        "tooltip": true,
        "on-click": "~/.config/rofi/powermenu.sh",
        "return-type": "json",
        "exec": "echo '{\"tooltip\": \"Power Menu\"}'",
        "interval": "once"
    },
    "custom/recorder": {
        "exec-if": "pgrep -x wf-recorder",
        "exec": "echo '{\"text\": \"ï€½\", \"tooltip\": \"Recording...\\n\\nLeft Click: Stop Recording\"}'",
        "return-type": "json",
        "interval": 1,
        "signal": 9,
        "format": "<span color='#f7768e'> {text} </span>",
        "on-click": "killall -s SIGINT wf-recorder"
    },
    "custom/autosleep": {
        "exec-if": "test -f ~/.config/sway/.autosleep_disabled",
        "exec": "echo '{\"text\": \"َ°…¶\", \"tooltip\": \"Autosleep is OFF (Caffeine Mode)\\n\\nLeft Click: Enable Autosleep\"}'",
        "return-type": "json",
        "interval": 2,
        "format": "<span color='#e0af68'> {text} </span>",
        "on-click": "~/.config/waybar/toggle_idle.sh"
    },
    "custom/capslock": {
        "exec-if": "grep -q '1' /sys/class/leds/*capslock/brightness 2>/dev/null",
        "exec": "echo '{\"text\": \"َ°ھ›\", \"tooltip\": \"Caps Lock is ON\"}'",
        "return-type": "json",
        "interval": 1,
        "format": "<span color='#f7768e'> {text} </span>"
    },
    "custom/clipse": {
        "exec": "echo '{\"text\": \"َ°…Œ\", \"tooltip\": \"Clipboard Manager\"}'",
        "return-type": "json",
        "interval": "once",
        "format": "<span color='#bb9af7'> {text} </span>",
        "on-click": "~/.config/sway/clipse-toggle.sh"
    }
}

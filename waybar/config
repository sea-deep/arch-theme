{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 3,
    "margin-left": 3,
    "margin-right": 3,
    "margin-bottom": 0,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/swaync", "group/hardware", "custom/power"],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "backlight", "custom/battery"]
    },

    "tray": {
        "spacing": 10
    },

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/window": {
        "max-length": 50
    },
    "clock": {
        "format": "<span color='#bb9af7'>≤░ξΦ</span>  {:%I:%M %p   <span color='#7aa2f7'>≤░Δφ</span>  %b %e}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/battery": {
        "exec": "~/.config/waybar/battery.sh",
        "on-click": "~/.config/waybar/tlp_menu.sh",
        "return-type": "json",
        "interval": 10,
        "format": "<span color='#39c5bb'>{alt}</span> {text}"
    },
    "network": {
        "format-wifi": "<span color='#7dcfff'>≤░νρ</span>   {essid}",
        "format-ethernet": "<span color='#7dcfff'>≤░ΙΑ</span>   {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr} ≤░ΛΩ",
        "format-linked": "{ifname} (No IP) ≤░ΙΑ",
        "format-disconnected": "<span color='#F7768E'>≤░νφ</span>   Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "tooltip": false,
        "format": "<span color='#7aa2f7'>{icon}</span> {volume}%",
        "format-bluetooth": "<span color='#7aa2f7'>{icon}≤░Γ░</span> {volume}%",
        "format-bluetooth-muted": "<span color='#F7768E'>≤░ΨΒ≤░Γ░</span>",
        "format-muted": "<span color='#F7768E'>≤░ΨΒ</span> Muted",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "hands-free": "≤░ΜΜ",
            "headset": "≤░ΜΜ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        "on-click": "~/.config/waybar/pavu_toggle.sh",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "backlight": {
        "tooltip": false,
        "format": "<span color='#e0af68'>{icon}</span> {percent}%",
        "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
        "on-click-middle": "~/.config/waybar/toggle_idle.sh",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },
    "bluetooth": {
        "format": "<span color='#bb9af7'>≤░Γψ</span>  {status}",
        "format-disabled": "<span color='#F7768E'>≤░Γ▓</span>  Disabled",
        "format-connected": "<span color='#bb9af7'>≤░Γ▒</span>  {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "pkill blueman-manager || blueman-manager"
    },
    "custom/swaync": {
        "tooltip": false,
        "format": "<span color='#bb9af7'> {icon} </span>",
        "format-icons": {
            "notification": "≤▒Ζτ",
            "none": "≤░Γγ",
            "dnd-notification": "≤▒Ππ",
            "dnd-none": "≤▒Ππ",
            "inhibited-notification": "≤▒Ζτ",
            "inhibited-none": "≤░Γγ",
            "dnd-inhibited-notification": "≤▒Ππ",
            "dnd-inhibited-none": "≤▒Ππ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/power": {
        "format": " ΎΑΣ ",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu.sh",
        "exec": "echo 'ΎΑΣ'",
        "interval": "once"
    }
}
